{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Product",
  "type": "object",
  "required": ["id", "title", "price", "description", "category", "image"],
  "properties": {
    "id": {
      "type": "number"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "price": {
      "type": "number"
    },
    "description": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "image": {
      "type": "string",
      "format": "uri"
    },
    "rating": {
      "type": "object",
      "properties": {
        "rate": { "type": "number" },
        "count": { "type": "number" }
      }
    }
  }
}
