{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cart",
  "type": "object",
  "required": ["id", "userId", "products"],
  "properties": {
    "id": {
      "type": "number"
    },
    "userId": {
      "type": "number"
    },
    "date": {
      "type": "string"
    },
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["productId", "quantity"],
        "properties": {
          "productId": {
            "type": "number"
          },
          "quantity": {
            "type": "number"
          }
        }
      }
    }
  }
}
